{
  "name": "sheetflare",
  "version": "0.1.0",
  "description": "Expose and manage your Google Sheets as a REST API with Cloudflare Workers and Durable Objects. Built for self-hosted deployments.",  
  "author": "Luke Zehrung <me@lukezehrung.com>",
  "license": "MIT",
  "homepage": "https://github.com/lzehrung/sheetflare",
  "repository": {
    "type": "git",
    "url": "https://github.com/lzehrung/sheetflare"
  },
  "bugs": "https://github.com/lzehrung/sheetflare/issues",
  "keywords": [
    "google sheets",
    "rest api",
    "cloudflare workers",
    "durable objects"
  ],
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "lint": "eslint .",
    "typecheck": "npm run -ws typecheck && tsc -p tsconfig.scripts.json --noEmit",
    "test": "npm run -ws test && vitest run --config vitest.config.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "dev:api": "npm --workspace @sheetflare/api run dev",
    "dev:admin": "npm --workspace @sheetflare/admin run dev",
    "e2e:browser": "tsx scripts/admin-browser-e2e.ts",
    "e2e:local": "tsx scripts/local-e2e.ts",
    "setup": "tsx scripts/setup.ts",
    "setup:verify": "tsx scripts/setup.ts --verify",
    "deploy:api": "npm --workspace @sheetflare/api run deploy",
    "deploy:admin": "npm --workspace @sheetflare/admin run deploy",
    "deploy": "npm run deploy:api && npm run deploy:admin",
    "deploy:staging:api": "npm --workspace @sheetflare/api run deploy:staging",
    "deploy:staging:admin": "npm --workspace @sheetflare/admin run deploy:staging",
    "deploy:staging": "npm run deploy:staging:api && npm run deploy:staging:admin",
    "ops:create-admin-key": "tsx scripts/create-admin-key.ts",
    "ops:bootstrap": "tsx scripts/bootstrap-run.ts",
    "smoke": "tsx scripts/smoke-run.ts",
    "load": "tsx scripts/load-run.ts",
    "ops:cache": "tsx scripts/get-cache-status.ts",
    "ops:cache:health": "tsx scripts/check-cache-health.ts",
    "ops:watch:drive": "tsx scripts/register-drive-watches.ts",
    "ops:watch:drive:status": "tsx scripts/get-drive-watch-status.ts",
    "ops:reindex": "tsx scripts/reindex-table.ts",
    "smoke:staging": "npm run smoke",
    "load:staging": "npm run load"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.9.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
