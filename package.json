{
  "name": "sheetflare",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "lint": "eslint .",
    "typecheck": "npm run -ws typecheck && tsc -p tsconfig.scripts.json --noEmit",
    "test": "npm run -ws test && vitest run scripts/lib/runtime.test.ts",
    "check": "npm run typecheck && npm run test",
    "dev:api": "npm --workspace @sheetflare/api run dev",
    "dev:admin": "npm --workspace @sheetflare/admin run dev",
    "ops:create-admin-key": "tsx scripts/create-admin-key.ts",
    "ops:cache": "tsx scripts/get-cache-status.ts",
    "ops:reindex": "tsx scripts/reindex-table.ts",
    "smoke:staging": "tsx scripts/smoke-staging.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.9.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
